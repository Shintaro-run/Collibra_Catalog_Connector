# Copy this file to .env and fill in real values.
# .env is gitignored — never commit actual secrets.

# Collibra instance base URL (no trailing slash)
# e.g. https://yourcompany.collibra.com
COLLIBRA_BASE_URL=https://your-instance.collibra.com

# OAuth Client Credentials (Type: Integration, Grant: Client Credentials)
# Obtain from: Collibra > Settings > Manage OAuth applications > Add
COLLIBRA_CLIENT_ID=your_client_id_here
COLLIBRA_CLIENT_SECRET=your_client_secret_here

# Optional: request timeout (seconds)
COLLIBRA_TIMEOUT=30
